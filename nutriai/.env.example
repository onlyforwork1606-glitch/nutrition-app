# NutriAI environment configuration
# Copy this file to `.env` and fill in your keys. NEVER commit `.env`.
#
# NOTE: Vite only exposes variables prefixed with VITE_ to the client
# (via import.meta.env). These are build-time fallbacks; the preferred way
# to set the key is at runtime in Settings -> OpenRouter API Key.

# OpenRouter API key (https://openrouter.ai/keys). Required for AI features.
VITE_OPENROUTER_API_KEY=

# Optional: override the OpenRouter base URL
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: a site identifier sent to OpenRouter for analytics
VITE_OPENROUTER_SITE_URL=https://nutriai.app
VITE_OPENROUTER_APP_NAME=NutriAI
